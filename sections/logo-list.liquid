<section
  id="logo-list-{{ section.id }}"
  class="logo-list section-spacing"
  style="--logo-opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }}; --logo-height: {{ section.settings.logo_height }}px; --section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="logo-list"
>
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header" data-aos="fade-up">
        <h2 class="section-header__heading h3">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="logo-list__grid" role="list" data-aos="fade-up" data-aos-delay="100">
      {%- for block in section.blocks -%}
        <div
          class="logo-list__item"
          role="listitem"
          data-aos="fade-up"
          data-aos-delay="{{ forloop.index | times: 80 }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="logo-list__link" target="_blank" rel="noopener" aria-label="{{ block.settings.alt | default: 'Logo partenaire' | escape }}">
          {%- endif -%}

          {%- if block.settings.image != blank -%}
            {%- assign logo_height_2x = section.settings.logo_height | times: 2 -%}
            <img
              src="{{ block.settings.image | image_url: height: section.settings.logo_height }}"
              srcset="
                {{ block.settings.image | image_url: height: section.settings.logo_height }} 1x,
                {{ block.settings.image | image_url: height: logo_height_2x }} 2x
              "
              alt="{{ block.settings.alt | default: 'Logo partenaire' | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              class="logo-list__image"
            >
          {%- else -%}
            <div class="logo-list__placeholder">
              {{ 'image' | placeholder_svg_tag: 'logo-list__placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Logos partenaires",
  "tag": "section",
  "class": "section-logo-list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Ils nous font confiance"
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "%",
      "label": "Opacité des logos",
      "info": "Réduire l'opacité crée un effet plus subtil et élégant"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 30,
      "max": 120,
      "step": 5,
      "default": 60,
      "unit": "px",
      "label": "Hauteur maximale des logos"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Espacement supérieur"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Espacement inférieur"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image du logo"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Texte alternatif",
          "info": "Description du logo pour l'accessibilité"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien",
          "info": "Optionnel. Rend le logo cliquable."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logos partenaires"
    }
  ]
}
{% endschema %}
