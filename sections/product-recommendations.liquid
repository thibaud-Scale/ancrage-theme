{%- if recommendations.performed and recommendations.products.size > 0 -%}
  <section class="product-recommendations section-padding" data-section-id="{{ section.id }}" aria-label="{{ section.settings.heading }}">
    <div class="container">
      <div class="section-header text-center">
        <h2 class="section-header__title h3">{{ section.settings.heading }}</h2>
      </div>

      <div class="product-grid product-grid--{{ section.settings.products_count }}">
        {%- for product in recommendations.products limit: section.settings.products_count -%}
          <div class="product-grid__item">
            {% render 'product-card', product: product %}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

<style>
  .product-recommendations {
    background: var(--color-surface-subtle, #faf9f7);
  }

  .product-recommendations .section-header {
    margin-bottom: 2rem;
  }

  .product-recommendations .section-header__title {
    font-family: var(--font-heading);
    color: var(--color-text, #2c2c2c);
  }

  .product-recommendations .product-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 768px) {
    .product-recommendations .product-grid {
      grid-template-columns: repeat(var(--rec-cols, 4), 1fr);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) {
      // Load recommendations via API
      var productId = {{ product.id | default: 'null' }};
      if (productId) {
        var url = '{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id=' + productId + '&limit={{ section.settings.products_count }}';
        fetch(url)
          .then(function (response) { return response.text(); })
          .then(function (html) {
            var container = document.querySelector('[data-section-id="{{ section.id }}"]');
            if (container) {
              container.outerHTML = html;
            }
          });
      }
    }
  });
</script>

{% schema %}
{
  "name": "Recommandations produit",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Vous aimerez aussi"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Nombre de produits",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ]
}
{% endschema %}
