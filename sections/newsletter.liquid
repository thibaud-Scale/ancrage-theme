{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}

<section
  id="newsletter-{{ section.id }}"
  class="newsletter section-spacing"
  style="--newsletter-bg: {{ section.settings.bg_color }}; --newsletter-text: {{ section.settings.text_color }}; --section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="newsletter"
>
  <div class="container">
    <div class="newsletter__inner" data-aos="fade-up">
      <div class="newsletter__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="newsletter__heading h2">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="newsletter__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      <div class="newsletter__form-wrapper" data-aos="fade-up" data-aos-delay="100">
        {% form 'customer', class: 'newsletter__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.errors -%}
            <div class="newsletter__message newsletter__message--error" role="alert">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="15" y1="9" x2="9" y2="15"></line>
                <line x1="9" y1="9" x2="15" y2="15"></line>
              </svg>
              <span>{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</span>
            </div>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <div class="newsletter__message newsletter__message--success" role="status">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              <span>Merci pour votre inscription !</span>
            </div>
          {%- endif -%}

          <div class="newsletter__input-group">
            <label for="newsletter-email-{{ section.id }}" class="visually-hidden">Adresse e-mail</label>
            <input
              type="email"
              name="contact[email]"
              id="newsletter-email-{{ section.id }}"
              class="newsletter__input"
              placeholder="Votre adresse e-mail"
              required
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              {% if form.posted_successfully? %}value=""{% endif %}
            >
            <button type="submit" class="btn btn--primary newsletter__submit">
              {{ section.settings.button_text }}
            </button>
          </div>

          {%- if section.settings.privacy_text != blank -%}
            <p class="newsletter__privacy">{{ section.settings.privacy_text }}</p>
          {%- endif -%}
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Restez informé"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Inscrivez-vous à notre newsletter pour recevoir nos actualités, nos offres exclusives et nos conseils d'expert."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texte du bouton",
      "default": "S'inscrire"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Texte de confidentialité",
      "default": "En vous inscrivant, vous acceptez notre politique de confidentialité. Désabonnement possible à tout moment.",
      "info": "Texte affiché sous le formulaire"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur d'arrière-plan",
      "default": "#2c2c2c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement supérieur"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement inférieur"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
