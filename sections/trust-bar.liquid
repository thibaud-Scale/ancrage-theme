<section
  id="trust-bar-{{ section.id }}"
  class="trust-bar section-spacing"
  style="--trust-bar-bg: {{ section.settings.bg_color }}; --section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="trust-bar"
  aria-label="Nos engagements"
>
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header" data-aos="fade-up">
        <h2 class="section-header__heading h3">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="trust-bar__grid" role="list">
      {%- for block in section.blocks -%}
        <div
          class="trust-bar__item"
          role="listitem"
          data-aos="fade-up"
          data-aos-delay="{{ forloop.index | times: 100 }}"
          {{ block.shopify_attributes }}
        >
          <div class="trust-bar__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="15" height="13"></rect>
                  <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                  <circle cx="5.5" cy="18.5" r="2.5"></circle>
                  <circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
              {%- when 'shield' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 12 11 14 15 10"></polyline>
                </svg>
              {%- when 'refresh' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 4 23 10 17 10"></polyline>
                  <polyline points="1 20 1 14 7 14"></polyline>
                  <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                </svg>
              {%- when 'phone' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
              {%- when 'star' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              {%- when 'clock' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            {%- endcase -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="trust-bar__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.subtitle != blank -%}
            <p class="trust-bar__subtitle">{{ block.settings.subtitle }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Barre de confiance",
  "tag": "section",
  "class": "section-trust-bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "info": "Optionnel. Laissez vide pour masquer."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur d'arrière-plan",
      "default": "#f8f6f3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Espacement supérieur"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Espacement inférieur"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge de confiance",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "options": [
            { "value": "truck", "label": "Camion (livraison)" },
            { "value": "shield", "label": "Bouclier (sécurité)" },
            { "value": "refresh", "label": "Flèches (retours)" },
            { "value": "phone", "label": "Téléphone (contact)" },
            { "value": "star", "label": "Étoile (qualité)" },
            { "value": "clock", "label": "Horloge (rapidité)" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Livraison rapide"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Sous-titre",
          "default": "Expédition sous 24-48h"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre de confiance",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "truck",
            "title": "Livraison rapide",
            "subtitle": "Expédition sous 24-48h"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "shield",
            "title": "Paiement sécurisé",
            "subtitle": "Transactions 100% protégées"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "refresh",
            "title": "Satisfait ou remboursé",
            "subtitle": "Retours gratuits sous 30 jours"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "phone",
            "title": "Service client",
            "subtitle": "À votre écoute du lundi au samedi"
          }
        }
      ]
    }
  ]
}
{% endschema %}
