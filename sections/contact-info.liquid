<section
  id="contact-info-{{ section.id }}"
  class="contact-info section-spacing"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="contact-info"
>
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header" data-aos="fade-up">
        <h2 class="section-header__heading h2">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="contact-info__grid" data-aos="fade-up" data-aos-delay="100">
      <div class="contact-info__details">
        {%- if section.settings.address != blank -%}
          <div class="contact-info__item">
            <div class="contact-info__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div class="contact-info__text">
              <h3 class="contact-info__label">Adresse</h3>
              <address class="contact-info__value">{{ section.settings.address | newline_to_br }}</address>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.phone != blank -%}
          <div class="contact-info__item">
            <div class="contact-info__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </div>
            <div class="contact-info__text">
              <h3 class="contact-info__label">Téléphone</h3>
              <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="contact-info__value contact-info__link">
                {{ section.settings.phone }}
              </a>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.email != blank -%}
          <div class="contact-info__item">
            <div class="contact-info__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div class="contact-info__text">
              <h3 class="contact-info__label">E-mail</h3>
              <a href="mailto:{{ section.settings.email }}" class="contact-info__value contact-info__link">
                {{ section.settings.email }}
              </a>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.hours != blank -%}
          <div class="contact-info__item">
            <div class="contact-info__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <div class="contact-info__text">
              <h3 class="contact-info__label">Horaires d'ouverture</h3>
              <p class="contact-info__value">{{ section.settings.hours | newline_to_br }}</p>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.show_social -%}
          <div class="contact-info__social">
            <h3 class="contact-info__label">Suivez-nous</h3>
            <div class="contact-info__social-links">
              {%- if settings.social_facebook_link != blank -%}
                <a href="{{ settings.social_facebook_link }}" class="contact-info__social-link" aria-label="Facebook" target="_blank" rel="noopener">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                  </svg>
                </a>
              {%- endif -%}
              {%- if settings.social_instagram_link != blank -%}
                <a href="{{ settings.social_instagram_link }}" class="contact-info__social-link" aria-label="Instagram" target="_blank" rel="noopener">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                  </svg>
                </a>
              {%- endif -%}
              {%- if settings.social_twitter_link != blank -%}
                <a href="{{ settings.social_twitter_link }}" class="contact-info__social-link" aria-label="Twitter" target="_blank" rel="noopener">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      <div class="contact-info__map" data-aos="fade-up" data-aos-delay="200">
        <div class="contact-info__map-placeholder" aria-label="Emplacement sur la carte">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <p>Carte interactive</p>
          <p class="contact-info__map-hint">Intégrez votre carte Google Maps via le code personnalisé du thème</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Informations de contact",
  "tag": "section",
  "class": "section-contact-info",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nous contacter"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Adresse",
      "default": "12 Rue de l'Artisanat\n33000 Bordeaux\nFrance"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Téléphone",
      "default": "05 56 00 00 00"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Adresse e-mail",
      "default": "contact@votre-boutique.fr"
    },
    {
      "type": "textarea",
      "id": "hours",
      "label": "Horaires d'ouverture",
      "default": "Lundi - Vendredi : 9h - 18h\nSamedi : 10h - 17h\nDimanche : Fermé"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Afficher les liens sociaux",
      "default": true,
      "info": "Utilise les liens sociaux définis dans les paramètres du thème"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement supérieur"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement inférieur"
    }
  ],
  "presets": [
    {
      "name": "Informations de contact"
    }
  ]
}
{% endschema %}
