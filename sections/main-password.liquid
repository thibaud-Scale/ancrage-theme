<section class="password-page" style="min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 40px 20px; background: var(--color-background, #F7F5F0);">
  <div style="max-width: 480px;">
    <h1 style="font-family: 'DM Serif Display', serif; font-size: 2.5rem; margin-bottom: 16px; color: var(--color-text, #1A1814);">
      {{ shop.name }}
    </h1>

    <p style="font-size: 1.1rem; color: var(--color-text-muted, #6B6660); margin-bottom: 32px;">
      {{ section.settings.heading | default: "Ouverture prochaine" }}
    </p>

    {%- if section.settings.show_message -%}
      <div style="margin-bottom: 32px; color: var(--color-text-muted, #6B6660);">
        {{ section.settings.message }}
      </div>
    {%- endif -%}

    {%- if section.settings.show_newsletter -%}
      {%- form 'customer', id: 'password-newsletter' -%}
        <input type="hidden" name="contact[tags]" value="prospect">
        <div style="display: flex; gap: 8px; max-width: 400px; margin: 0 auto 24px;">
          <input
            type="email"
            name="contact[email]"
            placeholder="Votre e-mail"
            required
            autocomplete="email"
            style="flex: 1; padding: 12px 16px; border: 1px solid var(--color-border, #ddd); border-radius: 8px; font-size: 1rem;"
          >
          <button type="submit" class="btn btn--primary" style="padding: 12px 24px; background: var(--color-accent, #C4853A); color: #fff; border: none; border-radius: 8px; font-size: 1rem; cursor: pointer;">
            S'inscrire
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p style="color: var(--color-success, #1E7A4A);">Merci ! Nous vous tiendrons informé.</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p style="color: var(--color-error, #c0392b);">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endform -%}
    {%- endif -%}

    {%- if section.settings.show_password_form -%}
      <details style="margin-top: 24px;">
        <summary style="cursor: pointer; font-size: 0.9rem; color: var(--color-text-muted, #6B6660);">
          Entrer avec un mot de passe
        </summary>
        <div style="margin-top: 16px;">
          {%- form 'storefront_password' -%}
            <div style="display: flex; gap: 8px; max-width: 400px; margin: 0 auto;">
              <input
                type="password"
                name="password"
                placeholder="Mot de passe"
                style="flex: 1; padding: 12px 16px; border: 1px solid var(--color-border, #ddd); border-radius: 8px; font-size: 1rem;"
              >
              <button type="submit" style="padding: 12px 24px; background: var(--color-text, #1A1814); color: #fff; border: none; border-radius: 8px; font-size: 1rem; cursor: pointer;">
                Entrer
              </button>
            </div>
            {%- if form.errors -%}
              <p style="color: var(--color-error, #c0392b); margin-top: 8px;">Mot de passe incorrect.</p>
            {%- endif -%}
          {%- endform -%}
        </div>
      </details>
    {%- endif -%}

    <p style="margin-top: 40px; font-size: 0.8rem; color: var(--color-text-faint, #A09B95);">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Page mot de passe",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Ouverture prochaine"
    },
    {
      "type": "richtext",
      "id": "message",
      "label": "Message"
    },
    {
      "type": "checkbox",
      "id": "show_message",
      "label": "Afficher le message",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Afficher le formulaire newsletter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_password_form",
      "label": "Afficher le formulaire mot de passe",
      "default": true
    }
  ]
}
{% endschema %}