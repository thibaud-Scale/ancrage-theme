{{ 'section-video.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign video_url = section.settings.video_url
  assign video_id = ''
  assign video_type = ''

  if video_url contains 'youtube.com' or video_url contains 'youtu.be'
    assign video_type = 'youtube'
    if video_url contains 'youtu.be'
      assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
    else
      assign video_id = video_url | split: 'v=' | last | split: '&' | first
    endif
  elsif video_url contains 'vimeo.com'
    assign video_type = 'vimeo'
    assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first
  endif
-%}

<section
  id="video-{{ section.id }}"
  class="video-section section-spacing"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="video"
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="section-header" data-aos="fade-up">
        {%- if section.settings.heading != blank -%}
          <h2 class="section-header__heading h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="section-header__subtitle">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="video-section__wrapper" data-aos="fade-up" data-aos-delay="100">
      <div
        class="video-section__player"
        data-video-type="{{ video_type }}"
        data-video-id="{{ video_id }}"
        data-video-url="{{ video_url }}"
      >
        {%- if section.settings.cover_image != blank -%}
          <div class="video-section__cover" data-video-cover>
            <img
              src="{{ section.settings.cover_image | image_url: width: 1280 }}"
              srcset="
                {{ section.settings.cover_image | image_url: width: 640 }} 640w,
                {{ section.settings.cover_image | image_url: width: 960 }} 960w,
                {{ section.settings.cover_image | image_url: width: 1280 }} 1280w
              "
              sizes="(max-width: 749px) 100vw, 80vw"
              alt="{{ section.settings.heading | default: 'Vidéo' | escape }}"
              loading="lazy"
              width="{{ section.settings.cover_image.width }}"
              height="{{ section.settings.cover_image.height }}"
              class="video-section__cover-image"
            >
            <button
              type="button"
              class="video-section__play-btn"
              aria-label="Lire la vidéo"
              data-video-play
            >
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                <circle cx="32" cy="32" r="31" stroke="currentColor" stroke-width="2" fill="rgba(0,0,0,0.3)"/>
                <polygon points="26,20 26,44 46,32" fill="currentColor"/>
              </svg>
            </button>
          </div>
        {%- endif -%}

        <div class="video-section__iframe-wrapper" {% if section.settings.cover_image != blank %}style="display:none"{% endif %} data-video-iframe>
          {%- if video_type == 'youtube' and video_id != blank -%}
            <iframe
              src="https://www.youtube-nocookie.com/embed/{{ video_id }}?rel=0&modestbranding=1"
              title="{{ section.settings.heading | default: 'Vidéo' | escape }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          {%- elsif video_type == 'vimeo' and video_id != blank -%}
            <iframe
              src="https://player.vimeo.com/video/{{ video_id }}?dnt=1"
              title="{{ section.settings.heading | default: 'Vidéo' | escape }}"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          {%- else -%}
            <div class="video-section__placeholder">
              <p>Ajoutez une URL YouTube ou Vimeo dans les paramètres de la section.</p>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var section = document.getElementById('video-{{ section.id }}');
    if (!section) return;
    var playBtn = section.querySelector('[data-video-play]');
    var cover = section.querySelector('[data-video-cover]');
    var iframeWrapper = section.querySelector('[data-video-iframe]');
    if (playBtn && cover && iframeWrapper) {
      playBtn.addEventListener('click', function() {
        cover.style.display = 'none';
        iframeWrapper.style.display = 'block';
        var iframe = iframeWrapper.querySelector('iframe');
        if (iframe) {
          var src = iframe.getAttribute('src');
          if (src.indexOf('autoplay') === -1) {
            iframe.setAttribute('src', src + (src.indexOf('?') > -1 ? '&' : '?') + 'autoplay=1');
          }
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Vidéo",
  "tag": "section",
  "class": "section-video",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "URL de la vidéo",
      "info": "URL YouTube ou Vimeo",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Image de couverture",
      "info": "Affichée avant la lecture de la vidéo. Si vide, la vidéo s'affiche directement."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Découvrez notre atelier"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "Plongez dans les coulisses de notre fabrication artisanale"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement supérieur"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement inférieur"
    }
  ],
  "presets": [
    {
      "name": "Vidéo"
    }
  ]
}
{% endschema %}
