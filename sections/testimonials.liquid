{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign layout = section.settings.layout
-%}

<section
  id="testimonials-{{ section.id }}"
  class="testimonials section-spacing"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="testimonials"
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="section-header" data-aos="fade-up">
        {%- if section.settings.heading != blank -%}
          <h2 class="section-header__heading h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="section-header__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="testimonials__{{ layout }}" {% if layout == 'carousel' %}data-carousel="testimonials"{% endif %}>
      {%- for block in section.blocks -%}
        <article
          class="testimonial-card"
          data-aos="fade-up"
          data-aos-delay="{{ forloop.index | times: 100 }}"
          {{ block.shopify_attributes }}
        >
          <div class="testimonial-card__inner">
            {%- if block.settings.rating > 0 -%}
              <div class="testimonial-card__rating" role="img" aria-label="{{ block.settings.rating }} étoiles sur 5">
                {%- for i in (1..5) -%}
                  <svg class="testimonial-card__star {% if i <= block.settings.rating %}testimonial-card__star--filled{% endif %}" width="18" height="18" viewBox="0 0 24 24" fill="{% if i <= block.settings.rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <blockquote class="testimonial-card__quote">
              <p>{{ block.settings.quote }}</p>
            </blockquote>

            <footer class="testimonial-card__author">
              {%- if block.settings.avatar != blank -%}
                <div class="testimonial-card__avatar">
                  <img
                    src="{{ block.settings.avatar | image_url: width: 80 }}"
                    alt="{{ block.settings.author | escape }}"
                    loading="lazy"
                    width="40"
                    height="40"
                  >
                </div>
              {%- endif -%}
              <div class="testimonial-card__author-info">
                {%- if block.settings.author != blank -%}
                  <cite class="testimonial-card__name">{{ block.settings.author }}</cite>
                {%- endif -%}
                {%- if block.settings.role != blank -%}
                  <span class="testimonial-card__role">{{ block.settings.role }}</span>
                {%- endif -%}
              </div>
            </footer>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Témoignages",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Ce que disent nos clients"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Des avis authentiques de nos clients satisfaits"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Disposition",
      "options": [
        { "value": "grid", "label": "Grille" },
        { "value": "carousel", "label": "Carrousel" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement supérieur"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement inférieur"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Témoignage",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Citation",
          "default": "Un travail remarquable et un service irréprochable. Je recommande vivement !"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Nom de l'auteur",
          "default": "Marie D."
        },
        {
          "type": "text",
          "id": "role",
          "label": "Rôle / Entreprise",
          "default": "Propriétaire de boutique"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Note (étoiles)"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Photo de l'auteur"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Témoignages",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "Un savoir-faire exceptionnel ! Les finitions sont parfaites et le produit a dépassé toutes mes attentes. Je suis cliente fidèle depuis 3 ans.",
            "author": "Marie Dupont",
            "role": "Gérante d'une boutique déco, Lyon",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Livraison rapide et produit conforme à la description. L'équipe est très réactive et le service après-vente est au top. Bravo !",
            "author": "Jean-Pierre Martin",
            "role": "Artisan menuisier, Bordeaux",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "J'ai offert leurs créations à mes clients les plus fidèles. Résultat : tout le monde est enchanté. Qualité française, on ne s'y trompe pas.",
            "author": "Sophie Lefèvre",
            "role": "Fleuriste, Nantes",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
