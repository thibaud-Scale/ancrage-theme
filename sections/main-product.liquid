<section class="main-product section-padding" data-section-id="{{ section.id }}" aria-label="Fiche produit">
  <div class="container">
    <div class="product-wrapper" data-product-id="{{ product.id }}">

      {%- comment -%} LEFT COLUMN: Image Gallery {%- endcomment -%}
      <div class="product-media" role="region" aria-label="Images du produit">
        <div class="product-media__main">
          {%- if product.compare_at_price > product.price -%}
            <span class="product-media__badge badge badge--sale" aria-label="En promotion">
              -{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%
            </span>
          {%- endif -%}

          <div class="product-media__viewer" id="product-main-image">
            {%- for media in product.media -%}
              <div
                class="product-media__slide{% if forloop.first %} is-active{% endif %}"
                data-media-id="{{ media.id }}"
                data-index="{{ forloop.index0 }}"
                {% if section.settings.enable_zoom %}data-zoom{% endif %}
              >
                {%- if media.media_type == 'image' -%}
                  <img
                    src="{{ media | image_url: width: 900 }}"
                    srcset="{{ media | image_url: width: 400 }} 400w, {{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
                    sizes="(min-width: 992px) 55vw, 100vw"
                    alt="{{ media.alt | escape }}"
                    width="{{ media.width }}"
                    height="{{ media.height }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    class="product-media__image"
                  >
                {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
                  {{ media | media_tag: class: 'product-media__video', loading: 'lazy' }}
                {%- elsif media.media_type == 'model' -%}
                  {{ media | media_tag: class: 'product-media__model' }}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>

          {%- if section.settings.enable_zoom -%}
            <div class="product-media__zoom-lens" aria-hidden="true"></div>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="product-media__thumbnails" role="tablist" aria-label="Miniatures du produit">
            {%- for media in product.media -%}
              <button
                class="product-media__thumbnail{% if forloop.first %} is-active{% endif %}"
                data-media-id="{{ media.id }}"
                data-index="{{ forloop.index0 }}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-controls="product-main-image"
                aria-label="Voir image {{ forloop.index }}"
              >
                <img
                  src="{{ media.preview_image | image_url: width: 120 }}"
                  alt="{{ media.alt | escape }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT COLUMN: Product Info {%- endcomment -%}
      <div class="product-info">
        {% render 'breadcrumb' %}

        {%- if section.settings.show_vendor and product.vendor != blank -%}
          <p class="product-info__vendor text-sm text-muted">
            <a href="{{ product.vendor | url_for_vendor }}">{{ product.vendor }}</a>
          </p>
        {%- endif -%}

        <h1 class="product-info__title h2">{{ product.title }}</h1>

        {%- if section.settings.show_rating -%}
          <div class="product-info__rating">
            {% render 'star-rating', product: product %}
          </div>
        {%- endif -%}

        <div class="product-info__price" id="product-price">
          {% render 'price', product: product %}
        </div>

        {%- assign short_desc = product.metafields.custom.short_description -%}
        {%- if short_desc != blank -%}
          <div class="product-info__short-description rte">
            {{ short_desc }}
          </div>
        {%- elsif product.description != blank -%}
          <div class="product-info__short-description rte">
            {{ product.description | strip_html | truncatewords: 30 }}
          </div>
        {%- endif -%}

        {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="product-variant-id">

          {%- unless product.has_only_default_variant -%}
            <div class="product-info__variants" id="product-variants">
              {%- for option in product.options_with_values -%}
                <fieldset class="product-info__option" data-option-index="{{ forloop.index0 }}">
                  <legend class="product-info__option-label">
                    {{ option.name }} : <span class="product-info__option-value" data-option-value>{{ option.selected_value }}</span>
                  </legend>
                  <div class="product-info__option-values">
                    {%- for value in option.values -%}
                      <label class="product-info__option-item">
                        <input
                          type="radio"
                          name="option-{{ option.name | handleize }}"
                          value="{{ value | escape }}"
                          {% if value == option.selected_value %}checked{% endif %}
                          data-option-input
                          class="sr-only"
                        >
                        <span class="product-info__option-swatch">{{ value }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </fieldset>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <div class="product-info__actions">
            <div class="product-info__quantity">
              {% render 'quantity-selector', id: 'product-quantity' %}
            </div>

            <button
              type="submit"
              class="product-info__add-to-cart btn btn--primary btn--large btn--full"
              {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
              id="add-to-cart-btn"
            >
              <span class="btn__text">
                {%- if product.selected_or_first_available_variant.available -%}
                  Ajouter au panier
                {%- else -%}
                  Rupture de stock
                {%- endif -%}
              </span>
              <span class="btn__loader" aria-hidden="true">
                <svg class="spinner" width="20" height="20" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="30 70"/></svg>
              </span>
            </button>

            {%- if section.settings.show_buy_now -%}
              {{ form | payment_button }}
            {%- endif -%}
          </div>
        {%- endform -%}

        <div class="product-info__trust">
          {% render 'trust-badges' %}
        </div>

        {%- comment -%} Accordion Blocks {%- endcomment -%}
        <div class="product-info__accordions" role="region" aria-label="Informations supplémentaires">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'description' -%}
                <details class="accordion" {{ block.shopify_attributes }} {% if forloop.first %}open{% endif %}>
                  <summary class="accordion__header">
                    <span class="accordion__title">{{ block.settings.heading | default: 'Description' }}</span>
                    <span class="accordion__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </summary>
                  <div class="accordion__content rte">
                    {{ product.description }}
                  </div>
                </details>

              {%- when 'shipping' -%}
                <details class="accordion" {{ block.shopify_attributes }}>
                  <summary class="accordion__header">
                    <span class="accordion__title">{{ block.settings.heading | default: 'Livraison & retours' }}</span>
                    <span class="accordion__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </summary>
                  <div class="accordion__content rte">
                    {%- if block.settings.content != blank -%}
                      {{ block.settings.content }}
                    {%- else -%}
                      <p>Livraison standard sous 3 à 5 jours ouvrés. Retours acceptés sous 14 jours.</p>
                    {%- endif -%}
                  </div>
                </details>

              {%- when 'details' -%}
                <details class="accordion" {{ block.shopify_attributes }}>
                  <summary class="accordion__header">
                    <span class="accordion__title">{{ block.settings.heading | default: 'Dimensions & détails' }}</span>
                    <span class="accordion__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </summary>
                  <div class="accordion__content rte">
                    {%- if block.settings.content != blank -%}
                      {{ block.settings.content }}
                    {%- elsif product.metafields.custom.dimensions != blank -%}
                      {{ product.metafields.custom.dimensions }}
                    {%- else -%}
                      <p>Consultez la description du produit pour plus de détails.</p>
                    {%- endif -%}
                  </div>
                </details>

              {%- when 'custom_tab' -%}
                <details class="accordion" {{ block.shopify_attributes }}>
                  <summary class="accordion__header">
                    <span class="accordion__title">{{ block.settings.heading }}</span>
                    <span class="accordion__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </summary>
                  <div class="accordion__content rte">
                    {{ block.settings.content }}
                  </div>
                </details>
            {%- endcase -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.show_share -%}
          <div class="product-info__sharing">
            {% render 'social-sharing', share_title: product.title, share_url: product.url, share_image: product.featured_image %}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <script type="application/json" id="product-json-{{ section.id }}">
    {{ product | json }}
  </script>

  <script type="application/json" id="product-variants-json-{{ section.id }}">
    {{ product.variants | json }}
  </script>
</section>

<style>
  .product-wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8, 2rem);
    align-items: start;
  }

  @media (min-width: 992px) {
    .product-wrapper {
      grid-template-columns: 1.5fr 1fr;
      gap: var(--spacing-12, 3rem);
    }
  }

  .product-media {
    position: relative;
  }

  .product-media__main {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg, 12px);
    background: var(--color-surface-subtle, #f8f7f5);
  }

  .product-media__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
    background: var(--color-accent, #c45e3a);
    color: #fff;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full, 50px);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .product-media__viewer {
    position: relative;
    aspect-ratio: 1;
  }

  .product-media__slide {
    display: none;
    width: 100%;
    height: 100%;
  }

  .product-media__slide.is-active {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-media__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  [data-zoom] .product-media__image:hover {
    transform: scale(1.5);
    cursor: zoom-in;
  }

  .product-media__thumbnails {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    overflow-x: auto;
    scrollbar-width: thin;
    padding-bottom: 0.25rem;
  }

  .product-media__thumbnail {
    flex: 0 0 auto;
    width: 72px;
    height: 72px;
    border: 2px solid transparent;
    border-radius: var(--radius-md, 8px);
    overflow: hidden;
    cursor: pointer;
    background: var(--color-surface-subtle, #f8f7f5);
    transition: border-color 0.2s ease;
    padding: 0;
  }

  .product-media__thumbnail.is-active,
  .product-media__thumbnail:hover {
    border-color: var(--color-primary, #2c2c2c);
  }

  .product-media__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-info {
    position: sticky;
    top: calc(var(--header-height, 80px) + 1rem);
  }

  .product-info__vendor {
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
  }

  .product-info__vendor a {
    color: var(--color-text-muted, #888);
    text-decoration: none;
  }

  .product-info__title {
    margin: 0 0 0.5rem;
    font-family: var(--font-heading);
    color: var(--color-text, #2c2c2c);
    line-height: 1.2;
  }

  .product-info__rating {
    margin-bottom: 0.75rem;
  }

  .product-info__price {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .product-info__short-description {
    margin-bottom: 1.5rem;
    color: var(--color-text-muted, #666);
    font-size: 0.938rem;
    line-height: 1.7;
  }

  .product-info__option {
    border: none;
    padding: 0;
    margin: 0 0 1.25rem;
  }

  .product-info__option-label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text, #2c2c2c);
  }

  .product-info__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .product-info__option-swatch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    border: 1.5px solid var(--color-border, #ddd);
    border-radius: var(--radius-md, 8px);
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: 44px;
    text-align: center;
    background: var(--color-background, #fff);
  }

  input[data-option-input]:checked + .product-info__option-swatch {
    border-color: var(--color-primary, #2c2c2c);
    background: var(--color-primary, #2c2c2c);
    color: #fff;
  }

  .product-info__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .product-info__quantity {
    max-width: 140px;
  }

  .product-info__add-to-cart {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .product-info__add-to-cart .btn__loader {
    display: none;
  }

  .product-info__add-to-cart.is-loading .btn__text {
    visibility: hidden;
  }

  .product-info__add-to-cart.is-loading .btn__loader {
    display: flex;
    position: absolute;
  }

  .product-info__trust {
    margin: 1.5rem 0;
    padding: 1rem 0;
    border-top: 1px solid var(--color-border, #eee);
    border-bottom: 1px solid var(--color-border, #eee);
  }

  .accordion {
    border-bottom: 1px solid var(--color-border, #eee);
  }

  .accordion__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1rem 0;
    cursor: pointer;
    list-style: none;
    font-weight: 500;
    font-size: 0.938rem;
    color: var(--color-text, #2c2c2c);
  }

  .accordion__header::-webkit-details-marker {
    display: none;
  }

  .accordion__icon {
    transition: transform 0.3s ease;
  }

  details[open] .accordion__icon {
    transform: rotate(180deg);
  }

  .accordion__content {
    padding: 0 0 1rem;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-muted, #666);
  }

  .product-info__sharing {
    margin-top: 1.5rem;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .spinner {
    animation: spin 0.8s linear infinite;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const thumbnails = section.querySelectorAll('.product-media__thumbnail');
    const slides = section.querySelectorAll('.product-media__slide');
    const variantIdInput = section.querySelector('#product-variant-id');
    const addToCartBtn = section.querySelector('#add-to-cart-btn');
    const optionInputs = section.querySelectorAll('[data-option-input]');
    const productData = JSON.parse(document.getElementById('product-json-{{ section.id }}').textContent);

    // Thumbnail click
    thumbnails.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        const index = this.dataset.index;
        thumbnails.forEach(function (t) { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
        slides.forEach(function (s) { s.classList.remove('is-active'); });
        this.classList.add('is-active');
        this.setAttribute('aria-selected', 'true');
        slides[index].classList.add('is-active');
      });
    });

    // Variant selection
    optionInputs.forEach(function (input) {
      input.addEventListener('change', function () {
        const selectedOptions = [];
        section.querySelectorAll('[data-option-input]:checked').forEach(function (checked) {
          selectedOptions.push(checked.value);
        });

        // Update displayed selected value
        const fieldset = this.closest('.product-info__option');
        const valueSpan = fieldset.querySelector('[data-option-value]');
        if (valueSpan) valueSpan.textContent = this.value;

        // Find matching variant
        var matchedVariant = null;
        for (var i = 0; i < productData.variants.length; i++) {
          var variant = productData.variants[i];
          var match = true;
          for (var j = 0; j < selectedOptions.length; j++) {
            if (variant.options[j] !== selectedOptions[j]) {
              match = false;
              break;
            }
          }
          if (match) {
            matchedVariant = variant;
            break;
          }
        }

        if (matchedVariant) {
          variantIdInput.value = matchedVariant.id;
          if (matchedVariant.available) {
            addToCartBtn.disabled = false;
            addToCartBtn.querySelector('.btn__text').textContent = 'Ajouter au panier';
          } else {
            addToCartBtn.disabled = true;
            addToCartBtn.querySelector('.btn__text').textContent = 'Rupture de stock';
          }

          // Update URL
          var url = new URL(window.location);
          url.searchParams.set('variant', matchedVariant.id);
          history.replaceState({}, '', url);
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Fiche produit",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Afficher le fabricant",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Afficher les étoiles",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_share",
      "label": "Afficher le partage social",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Afficher le bouton Acheter maintenant",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_zoom",
      "label": "Activer le zoom sur les images",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Description"
        }
      ]
    },
    {
      "type": "shipping",
      "name": "Livraison & retours",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Livraison & retours"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Contenu"
        }
      ]
    },
    {
      "type": "details",
      "name": "Dimensions & détails",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Dimensions & détails"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Contenu"
        }
      ]
    },
    {
      "type": "custom_tab",
      "name": "Onglet personnalisé",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Informations"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Contenu"
        }
      ]
    }
  ]
}
{% endschema %}
