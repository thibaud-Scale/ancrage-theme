<section class="main-blog section-padding" data-section-id="{{ section.id }}" aria-label="Blog {{ blog.title }}">
  <div class="container">
    <header class="blog-header">
      {% render 'breadcrumb' %}
      <h1 class="blog-header__title h2">{{ blog.title }}</h1>
    </header>

    {%- paginate blog.articles by section.settings.articles_per_page -%}
      {%- if blog.articles.size > 0 -%}
        <div class="blog-grid blog-grid--{{ section.settings.columns }}" role="list" aria-label="Articles">
          {%- for article in blog.articles -%}
            <article class="article-card" role="listitem">
              {%- if article.image -%}
                <a href="{{ article.url }}" class="article-card__image-link" aria-label="{{ article.title }}">
                  <div class="article-card__image">
                    <img
                      src="{{ article.image | image_url: width: 600 }}"
                      srcset="{{ article.image | image_url: width: 400 }} 400w, {{ article.image | image_url: width: 600 }} 600w"
                      sizes="(min-width: 992px) 33vw, (min-width: 768px) 50vw, 100vw"
                      alt="{{ article.image.alt | escape | default: article.title }}"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                      loading="lazy"
                    >
                  </div>
                </a>
              {%- endif -%}

              <div class="article-card__content">
                {%- if article.tags.size > 0 -%}
                  <span class="article-card__tag text-xs">{{ article.tags | first }}</span>
                {%- endif -%}

                <h2 class="article-card__title h5">
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h2>

                {%- if article.excerpt_or_content != blank -%}
                  <p class="article-card__excerpt text-sm text-muted">
                    {{ article.excerpt_or_content | strip_html | truncatewords: 20 }}
                  </p>
                {%- endif -%}

                <div class="article-card__meta text-xs text-muted">
                  <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                    {{ article.published_at | date: '%e %B %Y' }}
                  </time>
                  {%- assign words = article.content | strip_html | number_of_words -%}
                  {%- assign read_time = words | divided_by: 200 | at_least: 1 -%}
                  <span class="article-card__read-time">{{ read_time }} min de lecture</span>
                </div>
              </div>
            </article>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="Pagination du blog" role="navigation">
            <ul class="pagination__list">
              {%- if paginate.previous -%}
                <li>
                  <a href="{{ paginate.previous.url }}" class="pagination__link pagination__link--prev" aria-label="Page précédente">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Précédent
                  </a>
                </li>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                <li>
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="pagination__link">{{ part.title }}</a>
                  {%- elsif part.title == paginate.current_page -%}
                    <span class="pagination__link pagination__link--current" aria-current="page">{{ part.title }}</span>
                  {%- else -%}
                    <span class="pagination__link pagination__link--gap">{{ part.title }}</span>
                  {%- endif -%}
                </li>
              {%- endfor -%}

              {%- if paginate.next -%}
                <li>
                  <a href="{{ paginate.next.url }}" class="pagination__link pagination__link--next" aria-label="Page suivante">
                    Suivant
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="blog-empty text-center">
          <p class="text-muted">Aucun article pour le moment. Revenez bientôt !</p>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

<style>
  .blog-header {
    margin-bottom: 2.5rem;
  }

  .blog-header__title {
    font-family: var(--font-heading);
    color: var(--color-text, #2c2c2c);
    margin: 0.5rem 0 0;
  }

  .blog-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .blog-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .blog-grid--3 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 992px) {
    .blog-grid--3 { grid-template-columns: repeat(3, 1fr); }
  }

  .article-card {
    background: var(--color-background, #fff);
    border-radius: var(--radius-lg, 12px);
    overflow: hidden;
    border: 1px solid var(--color-border, #eee);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .article-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .article-card__image {
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .article-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .article-card:hover .article-card__image img {
    transform: scale(1.05);
  }

  .article-card__content {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .article-card__tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: var(--color-surface-subtle, #f0ede8);
    color: var(--color-text-muted, #666);
    border-radius: var(--radius-full, 50px);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .article-card__title {
    margin: 0 0 0.5rem;
    font-family: var(--font-heading);
    line-height: 1.3;
  }

  .article-card__title a {
    color: var(--color-text, #2c2c2c);
    text-decoration: none;
  }

  .article-card__title a:hover {
    color: var(--color-accent, #c45e3a);
  }

  .article-card__excerpt {
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .article-card__read-time::before {
    content: '·';
    margin-right: 0.5rem;
  }

  .blog-empty {
    padding: 4rem 2rem;
  }

  /* Pagination reuse from collection */
  .pagination {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border, #eee);
  }

  .pagination__list {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pagination__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-md, 8px);
    font-size: 0.875rem;
    color: var(--color-text, #2c2c2c);
    text-decoration: none;
    transition: all 0.2s;
  }

  .pagination__link:hover {
    background: var(--color-surface-subtle, #f0ede8);
  }

  .pagination__link--current {
    background: var(--color-primary, #2c2c2c);
    color: #fff;
  }

  .pagination__link--prev,
  .pagination__link--next {
    gap: 0.25rem;
    font-weight: 500;
  }
</style>

{% schema %}
{
  "name": "Page blog",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles par page",
      "min": 6,
      "max": 12,
      "step": 3,
      "default": 9
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Colonnes",
      "min": 2,
      "max": 3,
      "step": 1,
      "default": 3
    }
  ]
}
{% endschema %}
