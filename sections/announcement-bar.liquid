{%- if section.blocks.size > 0 -%}
  <div
    id="announcement-bar"
    class="announcement-bar"
    role="region"
    aria-label="Barre d'annonces"
    data-section-id="{{ section.id }}"
    data-auto-rotate="{{ section.settings.auto_rotate }}"
    data-rotation-speed="{{ section.settings.rotation_speed }}"
    style="
      background-color: {{ section.settings.bg_color }};
      color: {{ section.settings.text_color }};
    "
  >
    <div class="announcement-bar__container">
      <div class="announcement-bar__slider" aria-live="polite">
        {%- for block in section.blocks -%}
          <div
            class="announcement-bar__message{% if forloop.first %} is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            role="group"
            aria-roledescription="diapositive"
            aria-label="Annonce {{ forloop.index }} sur {{ section.blocks.size }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__link">
                <p class="announcement-bar__text">{{ block.settings.text }}</p>
              </a>
            {%- else -%}
              <p class="announcement-bar__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <div class="announcement-bar__controls">
          <button
            type="button"
            class="announcement-bar__prev"
            aria-label="Annonce précédente"
          >
            {% render 'icon', name: 'chevron-left' %}
          </button>
          <button
            type="button"
            class="announcement-bar__next"
            aria-label="Annonce suivante"
          >
            {% render 'icon', name: 'chevron-right' %}
          </button>
        </div>
      {%- endif -%}

      <button
        type="button"
        class="announcement-bar__close"
        aria-label="Fermer la barre d'annonces"
      >
        {% render 'icon', name: 'close' %}
      </button>
    </div>
  </div>
{%- endif -%}

<style>
  .announcement-bar {
    position: relative;
    z-index: 100;
    width: 100%;
    overflow: hidden;
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    line-height: 1.4;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }

  .announcement-bar.is-hidden {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
  }

  .announcement-bar__container {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0.5rem 2.5rem;
    min-height: 2.5rem;
  }

  .announcement-bar__slider {
    position: relative;
    width: 100%;
    text-align: center;
  }

  .announcement-bar__message {
    display: none;
    animation: announcementFadeIn 0.4s ease;
  }

  .announcement-bar__message.is-active {
    display: block;
  }

  @keyframes announcementFadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .announcement-bar__text {
    margin: 0;
    font-weight: 500;
  }

  .announcement-bar__link {
    color: inherit;
    text-decoration: none;
  }

  .announcement-bar__link:hover .announcement-bar__text {
    text-decoration: underline;
  }

  .announcement-bar__controls {
    display: flex;
    gap: 0.25rem;
    position: absolute;
    left: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .announcement-bar__prev,
  .announcement-bar__next,
  .announcement-bar__close {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: 0.25rem;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .announcement-bar__prev:hover,
  .announcement-bar__next:hover,
  .announcement-bar__close:hover {
    opacity: 1;
  }

  .announcement-bar__prev svg,
  .announcement-bar__next svg,
  .announcement-bar__close svg {
    width: 1rem;
    height: 1rem;
  }

  .announcement-bar__close {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
  }
</style>

<script>
  (function() {
    const bar = document.getElementById('announcement-bar');
    if (!bar) return;

    const messages = bar.querySelectorAll('.announcement-bar__message');
    const autoRotate = bar.dataset.autoRotate === 'true';
    const speed = parseInt(bar.dataset.rotationSpeed, 10) || 5;
    let current = 0;
    let interval = null;

    function showMessage(index) {
      messages.forEach(function(msg) { msg.classList.remove('is-active'); });
      messages[index].classList.add('is-active');
      current = index;
    }

    function next() {
      showMessage((current + 1) % messages.length);
    }

    function prev() {
      showMessage((current - 1 + messages.length) % messages.length);
    }

    function startRotation() {
      if (autoRotate && messages.length > 1) {
        interval = setInterval(next, speed * 1000);
      }
    }

    function stopRotation() {
      if (interval) clearInterval(interval);
    }

    var prevBtn = bar.querySelector('.announcement-bar__prev');
    var nextBtn = bar.querySelector('.announcement-bar__next');
    var closeBtn = bar.querySelector('.announcement-bar__close');

    if (prevBtn) {
      prevBtn.addEventListener('click', function() { stopRotation(); prev(); startRotation(); });
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', function() { stopRotation(); next(); startRotation(); });
    }
    if (closeBtn) {
      closeBtn.addEventListener('click', function() {
        stopRotation();
        bar.classList.add('is-hidden');
        sessionStorage.setItem('announcement-bar-dismissed', 'true');
      });
    }

    if (sessionStorage.getItem('announcement-bar-dismissed') === 'true') {
      bar.classList.add('is-hidden');
    } else {
      startRotation();
    }
  })();
</script>

{% schema %}
{
  "name": "Barre d'annonces",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#C4853A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#FFFFFF"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Rotation automatique",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Vitesse de rotation (secondes)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "s"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte de l'annonce",
          "default": "Livraison offerte dès 80€ d'achat"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre d'annonces",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "text": "Livraison offerte dès 80€ d'achat"
          }
        }
      ]
    }
  ]
}
{% endschema %}
