<section class="main-customers-register section-padding" data-section-id="{{ section.id }}" aria-label="Créer un compte">
  <div class="container">
    <div class="auth-wrapper">
      <div class="auth-card">
        <div class="auth-card__header text-center">
          <h1 class="auth-card__title h3">Créer un compte</h1>
          <p class="auth-card__subtitle text-muted">Rejoignez-nous et profitez d'une expérience personnalisée.</p>
        </div>

        {%- form 'create_customer' -%}
          {%- if form.errors -%}
            <div class="form-status form-status--error" role="alert">
              <p>{{ form.errors | default_errors }}</p>
            </div>
          {%- endif -%}

          <div class="form-grid form-grid--2">
            <div class="form-group">
              <label for="customer-first-name" class="form-label">Prénom</label>
              <input
                type="text"
                id="customer-first-name"
                name="customer[first_name]"
                autocomplete="given-name"
                required
                class="form-input"
                placeholder="Prénom"
              >
            </div>
            <div class="form-group">
              <label for="customer-last-name" class="form-label">Nom</label>
              <input
                type="text"
                id="customer-last-name"
                name="customer[last_name]"
                autocomplete="family-name"
                required
                class="form-input"
                placeholder="Nom"
              >
            </div>
          </div>

          <div class="form-group">
            <label for="customer-email" class="form-label">Adresse e-mail</label>
            <input
              type="email"
              id="customer-email"
              name="customer[email]"
              autocomplete="email"
              required
              class="form-input"
              placeholder="votre@email.fr"
            >
          </div>

          <div class="form-group">
            <label for="customer-password" class="form-label">Mot de passe</label>
            <input
              type="password"
              id="customer-password"
              name="customer[password]"
              autocomplete="new-password"
              required
              class="form-input"
              placeholder="Minimum 5 caractères"
              minlength="5"
            >
          </div>

          <button type="submit" class="btn btn--primary btn--large btn--full">
            Créer mon compte
          </button>
        {%- endform -%}

        <div class="auth-card__footer text-center">
          <p class="text-sm text-muted">
            Déjà un compte ?
            <a href="{{ routes.account_login_url }}" class="auth-link">Se connecter</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .auth-wrapper {
    max-width: 440px;
    margin: 0 auto;
  }

  .auth-card {
    background: var(--color-background, #fff);
    border: 1px solid var(--color-border, #eee);
    border-radius: var(--radius-lg, 12px);
    padding: 2.5rem 2rem;
  }

  .auth-card__header { margin-bottom: 2rem; }
  .auth-card__title { font-family: var(--font-heading); color: var(--color-text, #2c2c2c); margin: 0 0 0.5rem; }
  .auth-card__subtitle { margin: 0; font-size: 0.938rem; }
  .auth-card__footer { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border, #eee); }
  .auth-link { color: var(--color-accent, #c45e3a); font-weight: 500; text-decoration: none; }
  .auth-link:hover { text-decoration: underline; }

  .form-grid--2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 480px) { .form-grid--2 { grid-template-columns: 1fr; } }

  .form-group { margin-bottom: 1.25rem; }
  .form-label { display: block; margin-bottom: 0.375rem; font-size: 0.875rem; font-weight: 500; color: var(--color-text, #2c2c2c); }
  .form-input { width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--color-border, #ddd); border-radius: var(--radius-md, 8px); font-size: 0.938rem; font-family: inherit; transition: border-color 0.2s; background: var(--color-background, #fff); }
  .form-input:focus { outline: none; border-color: var(--color-primary, #2c2c2c); box-shadow: 0 0 0 3px rgba(44,44,44,0.1); }
  .form-status { padding: 1rem; border-radius: var(--radius-md, 8px); margin-bottom: 1rem; font-size: 0.875rem; }
  .form-status--error { background: #fce4ec; color: #c62828; }
</style>

{% schema %}
{
  "name": "Inscription client",
  "tag": "section",
  "settings": []
}
{% endschema %}
