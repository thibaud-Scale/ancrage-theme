{{ 'section-countdown.css' | asset_url | stylesheet_tag }}

<section
  id="countdown-{{ section.id }}"
  class="countdown section-spacing"
  style="--countdown-bg: {{ section.settings.bg_color }}; --section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="countdown"
>
  <div class="container">
    <div class="countdown__inner" data-aos="fade-up">
      {%- if section.settings.heading != blank -%}
        <h2 class="countdown__heading h2">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="countdown__text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.target_date != blank -%}
        <div
          class="countdown__timer"
          data-countdown="{{ section.settings.target_date }}"
          aria-label="Compte à rebours"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          <div class="countdown__unit">
            <span class="countdown__number" data-countdown-days>00</span>
            <span class="countdown__label">Jours</span>
          </div>
          <div class="countdown__separator" aria-hidden="true">:</div>
          <div class="countdown__unit">
            <span class="countdown__number" data-countdown-hours>00</span>
            <span class="countdown__label">Heures</span>
          </div>
          <div class="countdown__separator" aria-hidden="true">:</div>
          <div class="countdown__unit">
            <span class="countdown__number" data-countdown-minutes>00</span>
            <span class="countdown__label">Minutes</span>
          </div>
          <div class="countdown__separator" aria-hidden="true">:</div>
          <div class="countdown__unit">
            <span class="countdown__number" data-countdown-seconds>00</span>
            <span class="countdown__label">Secondes</span>
          </div>
        </div>

        <div class="countdown__expired" style="display:none" data-countdown-expired>
          <p>Cette offre est terminée !</p>
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <div class="countdown__button" data-aos="fade-up" data-aos-delay="200">
          <a
            href="{{ section.settings.button_link }}"
            class="btn btn--primary btn--large"
            {% if section.settings.button_link == blank %}aria-disabled="true"{% endif %}
          >
            {{ section.settings.button_text }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var timers = document.querySelectorAll('[data-countdown]');
    timers.forEach(function(timer) {
      var targetDate = new Date(timer.getAttribute('data-countdown')).getTime();
      var daysEl = timer.querySelector('[data-countdown-days]');
      var hoursEl = timer.querySelector('[data-countdown-hours]');
      var minutesEl = timer.querySelector('[data-countdown-minutes]');
      var secondsEl = timer.querySelector('[data-countdown-seconds]');
      var expiredEl = timer.parentElement.querySelector('[data-countdown-expired]');

      function pad(n) { return n < 10 ? '0' + n : n; }

      function update() {
        var now = new Date().getTime();
        var diff = targetDate - now;

        if (diff <= 0) {
          timer.style.display = 'none';
          if (expiredEl) expiredEl.style.display = 'block';
          return;
        }

        var days = Math.floor(diff / (1000 * 60 * 60 * 24));
        var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        var seconds = Math.floor((diff % (1000 * 60)) / 1000);

        if (daysEl) daysEl.textContent = pad(days);
        if (hoursEl) hoursEl.textContent = pad(hours);
        if (minutesEl) minutesEl.textContent = pad(minutes);
        if (secondsEl) secondsEl.textContent = pad(seconds);
      }

      update();
      setInterval(update, 1000);
    });
  });
</script>

{% schema %}
{
  "name": "Compte à rebours",
  "tag": "section",
  "class": "section-countdown",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Offre spéciale"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte promotionnel",
      "default": "Profitez de -20% sur toute la boutique ! Offre limitée."
    },
    {
      "type": "text",
      "id": "target_date",
      "label": "Date cible",
      "info": "Format : AAAA-MM-JJ HH:MM (ex. : 2026-12-31 23:59)",
      "default": "2026-12-31 23:59"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texte du bouton",
      "default": "En profiter maintenant"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur d'arrière-plan",
      "default": "#1a1a2e"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement supérieur"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement inférieur"
    }
  ],
  "presets": [
    {
      "name": "Compte à rebours"
    }
  ]
}
{% endschema %}
