{{ 'section-before-after.css' | asset_url | stylesheet_tag }}

<section
  id="before-after-{{ section.id }}"
  class="before-after section-spacing"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="before-after"
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="section-header" data-aos="fade-up">
        {%- if section.settings.heading != blank -%}
          <h2 class="section-header__heading h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="section-header__subtitle">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="before-after__slider" data-aos="fade-up" data-aos-delay="100" data-before-after-slider>
      <div class="before-after__wrapper" aria-label="Comparaison avant/après">
        <div class="before-after__before" data-before-after-before>
          {%- if section.settings.before_image != blank -%}
            <img
              src="{{ section.settings.before_image | image_url: width: 1200 }}"
              srcset="
                {{ section.settings.before_image | image_url: width: 600 }} 600w,
                {{ section.settings.before_image | image_url: width: 900 }} 900w,
                {{ section.settings.before_image | image_url: width: 1200 }} 1200w
              "
              sizes="(max-width: 749px) 100vw, 70vw"
              alt="{{ section.settings.before_label | default: 'Avant' | escape }}"
              loading="lazy"
              width="{{ section.settings.before_image.width }}"
              height="{{ section.settings.before_image.height }}"
              class="before-after__image"
              draggable="false"
            >
          {%- else -%}
            <div class="before-after__placeholder before-after__placeholder--before">
              {{ 'product-1' | placeholder_svg_tag: 'before-after__placeholder-svg' }}
            </div>
          {%- endif -%}
          <span class="before-after__label before-after__label--before" aria-hidden="true">
            {{ section.settings.before_label | default: 'Avant' }}
          </span>
        </div>

        <div class="before-after__after" data-before-after-after>
          {%- if section.settings.after_image != blank -%}
            <img
              src="{{ section.settings.after_image | image_url: width: 1200 }}"
              srcset="
                {{ section.settings.after_image | image_url: width: 600 }} 600w,
                {{ section.settings.after_image | image_url: width: 900 }} 900w,
                {{ section.settings.after_image | image_url: width: 1200 }} 1200w
              "
              sizes="(max-width: 749px) 100vw, 70vw"
              alt="{{ section.settings.after_label | default: 'Après' | escape }}"
              loading="lazy"
              width="{{ section.settings.after_image.width }}"
              height="{{ section.settings.after_image.height }}"
              class="before-after__image"
              draggable="false"
            >
          {%- else -%}
            <div class="before-after__placeholder before-after__placeholder--after">
              {{ 'product-2' | placeholder_svg_tag: 'before-after__placeholder-svg' }}
            </div>
          {%- endif -%}
          <span class="before-after__label before-after__label--after" aria-hidden="true">
            {{ section.settings.after_label | default: 'Après' }}
          </span>
        </div>

        <div class="before-after__handle" data-before-after-handle role="slider" aria-label="Curseur de comparaison avant/après" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50" tabindex="0">
          <div class="before-after__handle-line"></div>
          <div class="before-after__handle-circle">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
          <div class="before-after__handle-line"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var sliders = document.querySelectorAll('[data-before-after-slider]');
    sliders.forEach(function(slider) {
      var handle = slider.querySelector('[data-before-after-handle]');
      var beforeEl = slider.querySelector('[data-before-after-before]');
      var wrapper = slider.querySelector('.before-after__wrapper');
      if (!handle || !beforeEl || !wrapper) return;

      var isDragging = false;

      function setPosition(x) {
        var rect = wrapper.getBoundingClientRect();
        var percent = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
        beforeEl.style.width = percent + '%';
        handle.style.left = percent + '%';
        handle.setAttribute('aria-valuenow', Math.round(percent));
      }

      handle.addEventListener('mousedown', function(e) { isDragging = true; e.preventDefault(); });
      handle.addEventListener('touchstart', function(e) { isDragging = true; }, { passive: true });

      document.addEventListener('mousemove', function(e) { if (isDragging) setPosition(e.clientX); });
      document.addEventListener('touchmove', function(e) { if (isDragging) setPosition(e.touches[0].clientX); }, { passive: true });

      document.addEventListener('mouseup', function() { isDragging = false; });
      document.addEventListener('touchend', function() { isDragging = false; });

      handle.addEventListener('keydown', function(e) {
        var current = parseFloat(handle.getAttribute('aria-valuenow')) || 50;
        if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') {
          e.preventDefault();
          current = Math.max(0, current - 2);
        } else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') {
          e.preventDefault();
          current = Math.min(100, current + 2);
        }
        beforeEl.style.width = current + '%';
        handle.style.left = current + '%';
        handle.setAttribute('aria-valuenow', Math.round(current));
      });
    });
  });
</script>

{% schema %}
{
  "name": "Avant / Après",
  "tag": "section",
  "class": "section-before-after",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Avant / Après"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Découvrez la transformation réalisée par nos artisans"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Image « Avant »"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "Image « Après »"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Libellé « Avant »",
      "default": "Avant"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "Libellé « Après »",
      "default": "Après"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement supérieur"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement inférieur"
    }
  ],
  "presets": [
    {
      "name": "Avant / Après"
    }
  ]
}
{% endschema %}
