{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign columns = section.settings.columns
-%}

<section
  id="collection-list-{{ section.id }}"
  class="collection-list section-spacing"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-section-type="collection-list"
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="section-header" data-aos="fade-up">
        {%- if section.settings.heading != blank -%}
          <h2 class="section-header__heading h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="section-header__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="collection-list__grid grid grid--{{ columns }}-col">
      {%- for block in section.blocks -%}
        {%- assign coll = block.settings.collection -%}
        <div
          class="collection-list__item grid__item"
          data-aos="fade-up"
          data-aos-delay="{{ forloop.index | times: 100 }}"
          {{ block.shopify_attributes }}
        >
          <a href="{{ coll.url | default: '#' }}" class="collection-card" aria-label="{{ coll.title | default: 'Collection' | escape }}">
            <div class="collection-card__media">
              {%- if coll.featured_image != blank -%}
                <img
                  src="{{ coll.featured_image | image_url: width: 720 }}"
                  srcset="
                    {{ coll.featured_image | image_url: width: 360 }} 360w,
                    {{ coll.featured_image | image_url: width: 540 }} 540w,
                    {{ coll.featured_image | image_url: width: 720 }} 720w
                  "
                  sizes="(max-width: 749px) 100vw, {% if columns == 2 %}50vw{% elsif columns == 3 %}33vw{% else %}25vw{% endif %}"
                  alt="{{ coll.featured_image.alt | default: coll.title | escape }}"
                  loading="lazy"
                  width="{{ coll.featured_image.width }}"
                  height="{{ coll.featured_image.height }}"
                  class="collection-card__image"
                >
              {%- else -%}
                <div class="collection-card__placeholder">
                  {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'collection-card__placeholder-svg' }}
                </div>
              {%- endif -%}
              <div class="collection-card__overlay" aria-hidden="true"></div>
            </div>
            <div class="collection-card__content">
              <h3 class="collection-card__title">{{ coll.title | default: 'Nom de la collection' }}</h3>
              {%- if coll != blank -%}
                <span class="collection-card__count">
                  {{ coll.products_count }} produit{% if coll.products_count > 1 %}s{% endif %}
                </span>
              {%- endif -%}
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Liste de collections",
  "tag": "section",
  "class": "section-collection-list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nos collections"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Parcourez nos différentes gammes de produits"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Nombre de colonnes"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement supérieur"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Espacement inférieur"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Liste de collections"
    }
  ]
}
{% endschema %}
