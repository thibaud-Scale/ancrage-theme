{% comment %}
  Snippet: back-to-top.liquid
  Theme: Ancrage
  Usage: {% render 'back-to-top' %}
  Fixed bottom-right button to scroll back to top.
  Hidden by default, shown via JS on scroll.
{% endcomment %}

<button
  id="back-to-top"
  class="back-to-top"
  type="button"
  aria-label="Retour en haut de page"
  title="Retour en haut"
  hidden
  data-back-to-top
>
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
    <line x1="12" y1="19" x2="12" y2="5"></line>
    <polyline points="5 12 12 5 19 12"></polyline>
  </svg>
</button>

<script>
  (function() {
    var btn = document.getElementById('back-to-top');
    if (!btn) return;

    var scrollThreshold = 400;
    var isVisible = false;

    function toggleButton() {
      var shouldShow = window.scrollY > scrollThreshold;
      if (shouldShow !== isVisible) {
        isVisible = shouldShow;
        if (shouldShow) {
          btn.removeAttribute('hidden');
          requestAnimationFrame(function() {
            btn.classList.add('back-to-top--visible');
          });
        } else {
          btn.classList.remove('back-to-top--visible');
          btn.addEventListener('transitionend', function handler() {
            if (!isVisible) {
              btn.setAttribute('hidden', '');
            }
            btn.removeEventListener('transitionend', handler);
          });
        }
      }
    }

    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          toggleButton();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    btn.addEventListener('click', function() {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  })();
</script>

<style>
  .back-to-top {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background-color: #C4853A;
    color: #fff;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(196, 133, 58, 0.3);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.2s ease;
  }

  .back-to-top--visible {
    opacity: 1;
    transform: translateY(0);
  }

  .back-to-top:hover {
    background-color: #a86e2e;
    box-shadow: 0 4px 16px rgba(196, 133, 58, 0.4);
  }

  .back-to-top:focus-visible {
    outline: 2px solid #C4853A;
    outline-offset: 3px;
  }

  .back-to-top svg {
    width: 20px;
    height: 20px;
  }

  .back-to-top[hidden] {
    display: none;
  }

  @media (max-width: 767px) {
    .back-to-top {
      bottom: 16px;
      right: 16px;
      width: 40px;
      height: 40px;
    }

    .back-to-top svg {
      width: 18px;
      height: 18px;
    }
  }
</style>
