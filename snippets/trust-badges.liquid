{% comment %}
  Snippet: trust-badges.liquid
  Theme: Ancrage
  Usage: {% render 'trust-badges', style: 'horizontal' %}
  Accepts:
    - style {String} 'horizontal' (default) or 'vertical'
{% endcomment %}

{%- liquid
  assign badge_style = style | default: 'horizontal'
-%}

<div class="trust-badges trust-badges--{{ badge_style }}" role="list" aria-label="Garanties et engagements">
  <div class="trust-badges__item" role="listitem">
    <div class="trust-badges__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="1" y="3" width="15" height="13" rx="2"></rect>
        <polyline points="16 8 20 8 23 11 23 16 20 16"></polyline>
        <circle cx="5.5" cy="18.5" r="2.5"></circle>
        <circle cx="18.5" cy="18.5" r="2.5"></circle>
        <line x1="8" y1="18.5" x2="16" y2="18.5"></line>
      </svg>
    </div>
    <div class="trust-badges__text">
      <span class="trust-badges__label">Livraison gratuite</span>
      <span class="trust-badges__sublabel">Dès {{ settings.free_shipping_threshold | default: 50 }}€ d'achat</span>
    </div>
  </div>

  <div class="trust-badges__item" role="listitem">
    <div class="trust-badges__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        <polyline points="9 12 11 14 15 10"></polyline>
      </svg>
    </div>
    <div class="trust-badges__text">
      <span class="trust-badges__label">Paiement sécurisé</span>
      <span class="trust-badges__sublabel">Transactions 100% protégées</span>
    </div>
  </div>

  <div class="trust-badges__item" role="listitem">
    <div class="trust-badges__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="23 4 23 10 17 10"></polyline>
        <polyline points="1 20 1 14 7 14"></polyline>
        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"></path>
        <path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"></path>
      </svg>
    </div>
    <div class="trust-badges__text">
      <span class="trust-badges__label">Satisfait ou remboursé</span>
      <span class="trust-badges__sublabel">Retours sous 30 jours</span>
    </div>
  </div>

  <div class="trust-badges__item" role="listitem">
    <div class="trust-badges__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
    </div>
    <div class="trust-badges__text">
      <span class="trust-badges__label">Service client réactif</span>
      <span class="trust-badges__sublabel">Réponse sous 24h</span>
    </div>
  </div>
</div>

<style>
  .trust-badges {
    display: flex;
    gap: 24px;
    padding: 20px 0;
  }

  .trust-badges--horizontal {
    flex-direction: row;
    justify-content: center;
    flex-wrap: wrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .trust-badges--horizontal::-webkit-scrollbar {
    display: none;
  }

  .trust-badges--vertical {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .trust-badges__item {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    min-width: 0;
  }

  .trust-badges--vertical .trust-badges__item {
    width: 100%;
  }

  .trust-badges__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    background-color: #F7F5F0;
    border-radius: 50%;
    color: #C4853A;
  }

  .trust-badges__icon svg {
    width: 22px;
    height: 22px;
  }

  .trust-badges__text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .trust-badges__label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
    white-space: nowrap;
  }

  .trust-badges__sublabel {
    font-size: 0.75rem;
    color: #888;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .trust-badges--horizontal {
      flex-wrap: nowrap;
      justify-content: flex-start;
      padding: 16px 0;
      gap: 20px;
      scroll-snap-type: x mandatory;
    }

    .trust-badges--horizontal .trust-badges__item {
      scroll-snap-align: start;
    }
  }
</style>
