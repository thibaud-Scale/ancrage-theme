{% comment %}
  Snippet: quantity-selector.liquid
  Theme: Ancrage
  Usage: {% render 'quantity-selector', value: 1, min: 1, max: 10, name: 'quantity', id: 'qty-1' %}
  Accepts:
    - value {Number} Current quantity value
    - min {Number} Minimum value (default: 1)
    - max {Number} Maximum value (default: 99)
    - name {String} Input name attribute
    - id {String} Unique identifier for the input
{% endcomment %}

{%- liquid
  assign qty_value = value | default: 1
  assign qty_min = min | default: 1
  assign qty_max = max | default: 99
  assign qty_name = name | default: 'quantity'
  assign qty_id = id | default: 'quantity'
  if qty_max <= 0
    assign qty_max = 99
  endif
-%}

<div class="quantity-selector" data-quantity-selector>
  <button
    type="button"
    class="quantity-selector__btn quantity-selector__btn--minus"
    aria-label="Diminuer la quantité"
    data-quantity-minus
    {% if qty_value <= qty_min %}disabled aria-disabled="true"{% endif %}
  >
    {% render 'icon', name: 'minus' %}
  </button>

  <label for="quantity-input-{{ qty_id }}" class="visually-hidden">Quantité</label>
  <input
    type="number"
    id="quantity-input-{{ qty_id }}"
    class="quantity-selector__input"
    name="{{ qty_name }}"
    value="{{ qty_value }}"
    min="{{ qty_min }}"
    max="{{ qty_max }}"
    step="1"
    inputmode="numeric"
    pattern="[0-9]*"
    aria-label="Quantité"
    data-quantity-input
  >

  <button
    type="button"
    class="quantity-selector__btn quantity-selector__btn--plus"
    aria-label="Augmenter la quantité"
    data-quantity-plus
    {% if qty_value >= qty_max %}disabled aria-disabled="true"{% endif %}
  >
    {% render 'icon', name: 'plus' %}
  </button>
</div>

<style>
  .quantity-selector {
    display: inline-flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 6px;
    overflow: hidden;
    background-color: #fff;
  }

  .quantity-selector__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border: none;
    background: none;
    color: #1a1a1a;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
  }

  .quantity-selector__btn:hover:not(:disabled) {
    background-color: #F7F5F0;
    color: #C4853A;
  }

  .quantity-selector__btn:disabled {
    color: #ccc;
    cursor: not-allowed;
  }

  .quantity-selector__btn svg {
    width: 14px;
    height: 14px;
  }

  .quantity-selector__input {
    width: 40px;
    height: 32px;
    text-align: center;
    border: none;
    border-left: 1px solid #eee;
    border-right: 1px solid #eee;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: inherit;
    color: #1a1a1a;
    background: none;
    -moz-appearance: textfield;
    appearance: textfield;
    padding: 0;
  }

  .quantity-selector__input::-webkit-inner-spin-button,
  .quantity-selector__input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .quantity-selector__input:focus {
    outline: 2px solid #C4853A;
    outline-offset: -2px;
  }
</style>
