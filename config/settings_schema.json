  {
    "name": "Typographie",
    "settings": [
      {
        "type": "header",
        "content": "Titres"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Police des titres",
        "default": "dm_serif_display_n4",
        "info": "DM Serif Display — police serif élégante pour les titres."
      },
      {
        "type": "select",
        "id": "font_heading_weight",
        "label": "Graisse des titres",
        "default": "400",
        "options": [
          { "value": "400", "label": "Normal (400)" },
          { "value": "700", "label": "Gras (700)" }
        ]
      },
      {
        "type": "select",
        "id": "font_heading_transform",
        "label": "Transformation des titres",
        "default": "none",
        "options": [
          { "value": "none", "label": "Aucune" },
          { "value": "uppercase", "label": "MAJUSCULES" },
          { "value": "capitalize", "label": "Première Lettre" },
          { "value": "lowercase", "label": "minuscules" }
        ]
      },
      {
        "type": "range",
        "id": "font_heading_letter_spacing",
        "label": "Espacement des lettres (titres)",
        "default": 0,
        "min": -50,
        "max": 100,
        "step": 10,
        "unit": "ms"
      },
      {
        "type": "header",
        "content": "Corps de texte"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Police du corps",
        "default": "dm_sans_n4",
        "info": "DM Sans — police sans-serif lisible et moderne."
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "Taille de base (px)",
        "default": 16,
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "select",
        "id": "font_body_weight",
        "label": "Graisse du corps",
        "default": "400",
        "options": [
          { "value": "300", "label": "Léger (300)" },
          { "value": "400", "label": "Normal (400)" },
          { "value": "500", "label": "Moyen (500)" }
        ]
      },
      {
        "type": "range",
        "id": "font_body_line_height",
        "label": "Hauteur de ligne",
        "default": 1.6,
        "min": 1.2,
        "max": 2.0,
        "step": 0.1
      },
      {
        "type": "header",
        "content": "Échelle typographique"
      },
      {
        "type": "select",
        "id": "type_scale_ratio",
        "label": "Ratio d'échelle typographique",
        "default": "1.25",
        "info": "Détermine la progression de taille entre les niveaux de titre.",
        "options": [
          { "value": "1.125", "label": "1.125 — Seconde majeure (compact)" },
          { "value": "1.2", "label": "1.200 — Tierce mineure" },
          { "value": "1.25", "label": "1.250 — Quarte juste (recommandé)" },
          { "value": "1.333", "label": "1.333 — Quarte augmentée (aéré)" },
          { "value": "1.5", "label": "1.500 — Quinte juste (dramatique)" }
        ]
      }
    ]
  },
